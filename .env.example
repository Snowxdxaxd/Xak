# ─── Server ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
API_PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (PostgreSQL must be running locally)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codekids

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-secret-to-something-long-and-random

# ─── Root admin (created/updated on every server start) ───────────────────────
ROOT_ADMIN_EMAIL=admin@codekids.local
ROOT_ADMIN_PASSWORD=Admin12345!

# ─── Email (SMTP) — optional ──────────────────────────────────────────────────
# If left empty, email verification codes are printed to server console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@codekids.local

# ─── Examples for common SMTP providers ───────────────────────────────────────
# Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password   (create at myaccount.google.com/apppasswords)

# Yandex:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=587
#   SMTP_USER=your@yandex.ru
#   SMTP_PASS=your-password

# Mail.ru:
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=587
#   SMTP_USER=your@mail.ru
#   SMTP_PASS=your-app-password
