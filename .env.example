# ══════════════════════════════════════════════════════════════════════════════
# CodeKids — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For Docker, most values are set in docker-compose.yml.
# The .env file here is used for local development only.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# API base URL — do NOT change this for Docker or local dev
VITE_API_BASE_URL=/api

# ─── Server ───────────────────────────────────────────────────────────────────
API_PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: PostgreSQL must be running locally
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codekids

# Docker: uses the internal Docker network (set in docker-compose.yml)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/codekids

# ─── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-characters

# ─── Root superadmin ──────────────────────────────────────────────────────────
# This account is created/updated automatically on every server startup
ROOT_ADMIN_EMAIL=admin@codekids.local
ROOT_ADMIN_PASSWORD=Admin12345!

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
# Used for sending email verification codes during registration.
# Leave all SMTP_ fields empty to use CONSOLE fallback (codes printed to logs).
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password   ← use App Password, not account password
#   SMTP_FROM=your@gmail.com
#
# Yandex example:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=587
#   SMTP_USER=your@yandex.ru
#   SMTP_PASS=your-password
#   SMTP_FROM=your@yandex.ru
#
# Mail.ru example (use direct IP to avoid DNS issues):
#   SMTP_HOST=217.69.139.160
#   SMTP_PORT=587
#   SMTP_USER=your@mail.ru
#   SMTP_PASS=your-password
#   SMTP_FROM=your@mail.ru
SMTP_HOST=217.69.139.160
SMTP_PORT=587
SMTP_USER=iogankogan@bk.ru
SMTP_PASS=63Nc7YvihCFFyQfUneyb
SMTP_FROM=iogankogan@bk.ru
