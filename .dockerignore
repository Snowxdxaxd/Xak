# Dependencies (reinstalled inside Docker)
node_modules/

# Built output (rebuilt inside Docker)
dist/

# Secrets — never bake into the image
.env
.env.local
.env.*.local

# Version control
.git/
.gitignore

# Logs
*.log
npm-debug.log*

# Dev/docs folders (not needed in production image)
guidelines/
supabase/
utils/

# Uploads (mounted as volume, not baked into image)
uploads/

# OS files
.DS_Store
Thumbs.db

# Markdown (not needed at runtime)
*.md
ATTRIBUTIONS.md
